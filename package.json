{
	"name": "@rikalabs/shelf",
	"version": "0.1.0",
	"type": "module",
	"description": "A global cache of code reference repositories for AI agents",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Rika-Labs/shelf.git"
	},
	"bin": {
		"shelf": "./src/startup/index.ts"
	},
	"files": [
		"src/**/*.ts"
	],
	"scripts": {
		"shelf": "bun run src/startup/index.ts",
		"typecheck": "tsgo --noEmit",
		"test": "bun test",
		"format": "oxfmt src tests",
		"format:check": "oxfmt --check src tests",
		"lint": "oxlint --tsconfig tsconfig.json src tests",
		"lint:fix": "oxlint --fix --tsconfig tsconfig.json src tests",
		"check": "oxfmt --check src tests && oxlint --tsconfig tsconfig.json src tests && bunx --bun tsc --noEmit",
		"fix": "oxfmt src tests && oxlint --fix --tsconfig tsconfig.json src tests"
	},
	"dependencies": {
		"@effect/platform-bun": "4.0.0-beta.31",
		"effect": "4.0.0-beta.31"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"oxfmt": "^0.40.0",
		"oxlint": "^1.55.0"
	}
}
