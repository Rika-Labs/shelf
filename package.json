{
	"name": "@rikalabs/shelf",
	"version": "0.1.0",
	"type": "module",
	"description": "A global cache of code reference repositories for AI agents",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Rika-Labs/shelf.git"
